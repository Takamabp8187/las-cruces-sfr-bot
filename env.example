# Las Cruces SFR Bot — Environment Variables
# Copy this file to .env and fill in your values

# Your Gmail address (the one sending the report)
GMAIL_USER=your-gmail@gmail.com

# Gmail App Password — NOT your regular password!
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2FA to be enabled on your Google account)
GMAIL_APP_PASS=xxxx-xxxx-xxxx-xxxx

# Email address to receive the daily report
RECIPIENT_EMAIL=bartljordan@gmail.com

# Path to the JSON file that tracks seen listings
STATE_FILE=state.json
